  <ItemGroup>
    <!-- Явный HintPath на facade-сборки прямо внутри восстановленного NuGet-пакета,
         вместо надежды на implicit resolution через .props/.targets. Подтверждено
         логами: файлы реально лежат в ref\uap10.0.15138\ (включая System.Runtime.dll),
         но implicit resolution их не находит и лезет в desktop GAC — отсюда разом
         WMC1006, MSB3245 и MSB3277/MSB3270. Явный путь решает всё сразу. -->
    <Reference Include="mscorlib">
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\mscorlib.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System">
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Core">
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Core.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Runtime">
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Runtime.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Xml">
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Xml.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Xml.Linq">
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Xml.Linq.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Numerics">
      <!-- Нужна для System.Numerics.Complex в Helpers/FFT.cs -->
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Numerics.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Runtime.WindowsRuntime">
      <!-- Нужна XamlCompiler для проекции WinRT-типов (Color и т.п.) в App.xaml/MainPage.xaml -->
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Runtime.WindowsRuntime.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Runtime.WindowsRuntime.UI.Xaml">
      <!-- Нужна XamlCompiler для проекции XAML/UI-типов (Page, UIElement, Grid и т.п.) -->
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Runtime.WindowsRuntime.UI.Xaml.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Runtime.Numerics">
      <!-- Нужна для System.Numerics.Complex в Helpers/FFT.cs — сам тип лежит здесь, а не в System.Numerics.dll -->
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Runtime.Numerics.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Runtime.InteropServices">
      <!-- Нужна для ComImportAttribute/GuidAttribute/InterfaceTypeAttribute в Services/VisualizerService.cs -->
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Runtime.InteropServices.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Diagnostics.Tools">
      <!-- Нужна для GeneratedCodeAttribute в автогенерируемых App.g.i.cs/MainPage.g.i.cs -->
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Diagnostics.Tools.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Diagnostics.Debug">
      <!-- Нужна для DebuggerNonUserCodeAttribute в автогенерируемых App.g.i.cs/MainPage.g.i.cs -->
      <HintPath>$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\ref\uap10.0.15138\System.Diagnostics.Debug.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

