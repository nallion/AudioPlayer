      <SubType>Designer</SubType>
    </ApplicationDefinition>
    <Page Include="MainPage.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>

  <ItemGroup>
    <AppxManifest Include="Package.appxmanifest">
      <SubType>Designer</SubType>
    </AppxManifest>
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\StoreLogo.png" />
    <Content Include="Assets\Square44x44Logo.png" />
    <Content Include="Assets\Square150x150Logo.png" />
    <Content Include="Assets\Wide310x150Logo.png" />
    <Content Include="Assets\SplashScreen.png" />
  </ItemGroup>

  <ItemGroup>
    <None Include="packages.config" />
  </ItemGroup>

  <PropertyGroup>
    <VisualStudioVersion Condition="'$(VisualStudioVersion)' == ''">15.0</VisualStudioVersion>
  </PropertyGroup>

  <!-- Ключевой импорт: именно он подключает сборку XAML/UWP-проекта.
       Без него MSBuild не поймёт .xaml файлы и AppxManifest. -->
  <Import Project="$(MSBuildExtensionsPath)\Microsoft\WindowsXaml\v$(VisualStudioVersion)\Microsoft.Windows.UI.Xaml.CSharp.targets" />

  <!-- КРИТИЧЕСКИ ВАЖНО для packages.config-стиля: эти два импорта подключают
       .targets из самих NuGet-пакетов. Именно они добавляют ссылки на facade-сборки
       (System.Runtime и т.п.) и WinMD-метаданные UAP-контрактов. Без них
       XamlCompiler падает с WMC1006 "Cannot resolve assembly System.Runtime",
       а следом с ошибкой "не найден App.g.i.cs" — это просто следствие первой.
       При обычной установке через Visual Studio Package Manager эти строки
       NuGet дописывает в csproj сам; при ручном/CI-сценарии их нужно иметь здесь. -->
  <Import Project="$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\build\Microsoft.NETCore.UniversalWindowsPlatform.targets" Condition="Exists('$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\build\Microsoft.NETCore.UniversalWindowsPlatform.targets')" />
  <Import Project="$(SolutionDir)packages\Win2D.uwp.1.25.0\build\native\Win2D.uwp.targets" Condition="Exists('$(SolutionDir)packages\Win2D.uwp.1.25.0\build\native\Win2D.uwp.targets')" />

  <Target Name="EnsureNuGetPackageBuildImports" BeforeTargets="PrepareForBuild">
    <PropertyGroup>
      <ErrorText>Этот проект ссылается на пакеты NuGet, которых нет на этом компьютере. Включите восстановление пакетов NuGet перед сборкой. Отсутствующий файл: {0}</ErrorText>
    </PropertyGroup>
    <Error Condition="!Exists('$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\build\Microsoft.NETCore.UniversalWindowsPlatform.props')"
           Text="$([System.String]::Format('$(ErrorText)', '$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\build\Microsoft.NETCore.UniversalWindowsPlatform.props'))" />
    <Error Condition="!Exists('$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\build\Microsoft.NETCore.UniversalWindowsPlatform.targets')"
           Text="$([System.String]::Format('$(ErrorText)', '$(SolutionDir)packages\Microsoft.NETCore.UniversalWindowsPlatform.6.2.14\build\Microsoft.NETCore.UniversalWindowsPlatform.targets'))" />
    <Error Condition="!Exists('$(SolutionDir)packages\Win2D.uwp.1.25.0\build\native\Win2D.uwp.targets')"
           Text="$([System.String]::Format('$(ErrorText)', '$(SolutionDir)packages\Win2D.uwp.1.25.0\build\native\Win2D.uwp.targets'))" />
  </Target>
</Project>
