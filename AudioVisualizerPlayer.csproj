<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">ARM</Platform>
    <ProjectGuid>{9E4E7B1A-0000-4000-8000-000000000001}</ProjectGuid>
    <OutputType>AppContainerExe</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>AudioVisualizerPlayer</RootNamespace>
    <AssemblyName>AudioVisualizerPlayer</AssemblyName>
    <DefaultLanguage>ru-RU</DefaultLanguage>
    <TargetPlatformIdentifier>UAP</TargetPlatformIdentifier>
    <TargetPlatformVersion Condition=" '$(TargetPlatformVersion)' == '' ">10.0.17763.0</TargetPlatformVersion>
    <TargetPlatformMinVersion>10.0.15063.0</TargetPlatformMinVersion>
    <MinimumVisualStudioVersion>14</MinimumVisualStudioVersion>
    <FileAlignment>512</FileAlignment>
    <ProjectTypeGuids>{A5E7574B-450C-4C53-8BD3-B73C464AFCE0};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <WindowsTargetPlatformVersion>10.0.17763.0</WindowsTargetPlatformVersion>
    <AppxPackageSigningEnabled>false</AppxPackageSigningEnabled>
    <GenerateAppxPackageOnBuild>true</GenerateAppxPackageOnBuild>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|ARM'">
    <OutputPath>bin\ARM\Release\</OutputPath>
    <DefineConstants>TRACE;NETFX_CORE;WINDOWS_UWP</DefineConstants>
    <Optimize>true</Optimize>
    <NoWarn>;2008</NoWarn>
    <DebugType>pdbonly</DebugType>
    <PlatformTarget>ARM</PlatformTarget>
    <UseVSHostingProcess>false</UseVSHostingProcess>
    <ErrorReport>prompt</ErrorReport>
    <Prefer32Bit>true</Prefer32Bit>
    <!-- Возвращено в true по образцу рабочего проекта (nallion/tdlib_wp10) —
         похоже, что .NET Native сам по себе никогда не был причиной краша;
         настоящая причина была в неправильном (packages.config) стиле
         восстановления NuGet, из-за которого в пакет попадали facade-заглушки. -->
    <UseDotNetNativeToolchain>true</UseDotNetNativeToolchain>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|ARM'">
    <OutputPath>bin\ARM\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE;NETFX_CORE;WINDOWS_UWP</DefineConstants>
    <DebugType>full</DebugType>
    <PlatformTarget>ARM</PlatformTarget>
    <UseVSHostingProcess>false</UseVSHostingProcess>
    <ErrorReport>prompt</ErrorReport>
    <Prefer32Bit>true</Prefer32Bit>
  </PropertyGroup>

  <!-- КЛЮЧЕВОЕ ОТЛИЧИЕ от всех предыдущих версий: PackageReference вместо
       packages.config. Это заставляет NuGet правильно резолвить зависимости
       (корректное разделение compile-time/runtime, транзитивные зависимости),
       и НЕ бандлит compile-only facade-сборки в итоговый пакет — то есть
       вся наша многодневная эпопея с WMC1006 → 150 ручных Reference →
       FileLoadException была следствием изначально неверного выбора стиля
       restore. Никаких вручную прописанных Reference/Import для
       Microsoft.NETCore.UniversalWindowsPlatform больше не нужно —
       PackageReference подключает всё сама через автогенерируемые
       obj\*.csproj.nuget.g.targets/.props. -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NETCore.UniversalWindowsPlatform">
      <Version>6.2.14</Version>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="App.xaml.cs">
      <DependentUpon>App.xaml</DependentUpon>
    </Compile>
    <Compile Include="MainPage.xaml.cs">
      <DependentUpon>MainPage.xaml</DependentUpon>
    </Compile>
    <Compile Include="PlaylistPage.xaml.cs">
      <DependentUpon>PlaylistPage.xaml</DependentUpon>
    </Compile>
    <Compile Include="EqualizerPage.xaml.cs">
      <DependentUpon>EqualizerPage.xaml</DependentUpon>
    </Compile>
    <Compile Include="Models\PlaylistItem.cs" />
    <Compile Include="Services\PlaybackService.cs" />
    <Compile Include="Services\VisualizerService.cs" />
    <Compile Include="Helpers\FFT.cs" />
    <Compile Include="Helpers\Diag.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Include="App.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </ApplicationDefinition>
    <Page Include="MainPage.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Include="PlaylistPage.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Include="EqualizerPage.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>

  <ItemGroup>
    <AppxManifest Include="Package.appxmanifest">
      <SubType>Designer</SubType>
    </AppxManifest>
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\StoreLogo.png" />
    <Content Include="Assets\Square44x44Logo.png" />
    <Content Include="Assets\Square150x150Logo.png" />
    <Content Include="Assets\Wide310x150Logo.png" />
    <Content Include="Assets\SplashScreen.png" />
  </ItemGroup>

  <!-- Генерируем rd.xml на лету — нужен для .NET Native, чтобы reflection-метаданные
       наших типов и XAML-активируемых классов не срезались при AOT-компиляции.
       Раньше без него была warning "missing Runtime Directives" в самом первом
       .NET Native билде — тогда мы её проигнорировали, а зря. -->
  <Target Name="GenerateRdXml" BeforeTargets="PrepareForBuild">
    <PropertyGroup>
      <RdXmlPath>$(ProjectDir)Properties\Default.rd.xml</RdXmlPath>
      <RdXmlContent><![CDATA[<Directives xmlns="http://schemas.microsoft.com/netfx/2013/01/metadata">
  <Application>
    <Assembly Name="AudioVisualizerPlayer" Dynamic="Required All" />
  </Application>
</Directives>]]></RdXmlContent>
    </PropertyGroup>
    <MakeDir Directories="$(ProjectDir)Properties" />
    <WriteLinesToFile File="$(RdXmlPath)" Lines="$(RdXmlContent)" Overwrite="true" />
    <ItemGroup>
      <Content Include="$(RdXmlPath)" />
    </ItemGroup>
  </Target>

  <Import Project="$(MSBuildExtensionsPath)\Microsoft\WindowsXaml\v$(VisualStudioVersion)\Microsoft.Windows.UI.Xaml.CSharp.targets" />

  <!-- Автоподпись тестовым самоподписанным сертификатом прямо в билде —
       решает нашу давнюю проблему "пакет не подписан, sideload не ставится"
       без ручной генерации PFX на локальной машине. -->
  <Target Name="AutoSignAppx" AfterTargets="_BundleAppx;GenerateAppx">
    <PropertyGroup>
      <CertFile>$(ProjectDir)MyTempCert.pfx</CertFile>
      <CertPass>12345</CertPass>
      <AppxPath>$(AppxPackageOutput)</AppxPath>
    </PropertyGroup>

    <Message Importance="High" Text="--- НАЧАЛО ПРОЦЕССА ПОДПИСИ ПАКЕТА ---" />

    <Exec Condition="!Exists('$(CertFile)')"
          Command="MakeCert.exe -r -pe -n &quot;CN=DevCert&quot; -eku 1.3.6.1.5.5.7.3.3 -ss My -len 2048 -sky exchange &quot;$(ProjectDir)TempCert.cer&quot; &amp;&amp; Pvk2Pfx.exe -pvk &quot;$(ProjectDir)TempCert.pvk&quot; -spc &quot;$(ProjectDir)TempCert.cer&quot; -pfx &quot;$(CertFile)&quot; -pi $(CertPass)"
          IgnoreExitCode="true" />

    <Exec Condition="Exists('$(AppxPath)')"
          Command="SignTool.exe sign /fd SHA256 /a /f &quot;$(CertFile)&quot; /p $(CertPass) &quot;$(AppxPath)&quot;" />

    <Message Importance="High" Text="--- ПОДПИСЬ ЗАВЕРШЕНА: $(AppxPath) ---" />
  </Target>

</Project>
