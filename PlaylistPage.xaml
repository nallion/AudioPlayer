<Page
    x:Class="AudioVisualizerPlayer.PlaylistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Плейлист" FontSize="26" FontWeight="Light"
                   Foreground="White" Margin="16,16,16,8"/>

        <ListView x:Name="TracksList" Grid.Row="1"
                  IsItemClickEnabled="True" ItemClick="TracksList_ItemClick"
                  SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="16,10">
                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="16"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Artist}" Foreground="{StaticResource AppDimBrush}"
                                   FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
