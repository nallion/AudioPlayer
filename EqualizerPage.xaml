<Page
    x:Class="AudioVisualizerPlayer.EqualizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Эквалайзер" FontSize="26" FontWeight="Light"
                   Foreground="White" Margin="16,16,16,8"/>

        <!-- 5 вертикальных слайдеров, по одному на полосу. Сами полосы и их
             частоты создаются в коде (EqualizerPage.xaml.cs), т.к. Grid с
             колонками под них удобнее строить программно вместе с подписями. -->
        <Grid x:Name="BandsContainer" Grid.Row="1" Margin="12,8,12,24"/>
    </Grid>
</Page>
