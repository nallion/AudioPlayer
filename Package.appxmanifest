<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  IgnorableNamespaces="uap mp uap3">

  <Identity
    Name="AudioVisualizerPlayer"
    Publisher="CN=DevCert"
    Version="1.0.0.0" />

  <mp:PhoneIdentity PhoneProductId="9e4e7b1a-0000-4000-8000-000000000000" PhonePublisherId="00000000-0000-0000-0000-000000000000"/>

  <Properties>
    <DisplayName>Audio Visualizer Player</DisplayName>
    <PublisherDisplayName>Dev</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.15063.0" MaxVersionTested="10.0.17763.0" />
  </Dependencies>

  <Resources>
    <Resource Language="ru-RU"/>
  </Resources>

  <Applications>
    <Application Id="App" Executable="$targetnametoken$.exe" EntryPoint="AudioVisualizerPlayer.App">
      <uap:VisualElements
        DisplayName="Audio Visualizer Player"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png"
        Description="Аудиоплеер с фоновым воспроизведением и визуализатором"
        BackgroundColor="#000000">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>

      <!-- Отдельной декларации windows.backgroundTasks не нужно: современный
           Windows.Media.Playback.MediaPlayer вместе с SystemMediaTransportControls
           продолжает играть в фоне сам по себе, без отдельного класса-обработчика
           фоновой задачи (это было нужно только для устаревшего паттерна
           BackgroundMediaPlayer из эпохи Windows Phone 8.1). У нас и класса
           IBackgroundTask в проекте нет — декларация была лишней и к тому же
           не проходила валидацию схемы манифеста. -->
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
    <uap:Capability Name="musicLibrary" />
    <uap3:Capability Name="backgroundMediaPlayback" />
  </Capabilities>
</Package>
