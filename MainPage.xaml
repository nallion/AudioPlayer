<Page
    x:Class="AudioVisualizerPlayer.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>       <!-- визуализатор -->
            <RowDefinition Height="Auto"/>   <!-- название трека/исполнителя -->
            <RowDefinition Height="Auto"/>   <!-- прогресс -->
            <RowDefinition Height="Auto"/>   <!-- транспорт -->
        </Grid.RowDefinitions>

        <!-- Визуализатор на обычных XAML Rectangle (без Win2D) — Height каждого
             обновляется в code-behind при поступлении новых уровней из
             VisualizerService. Grid с равными звёздными колонками вместо
             StackPanel + хардкода ширины/высоты в пикселях — так визуализатор
             сам подстраивается под реальный размер экрана, а не занимает
             фиксированную полоску 300x70 независимо от того, сколько места
             реально доступно. -->
        <Grid x:Name="VisualizerPanel" Grid.Row="0" Margin="12,12,12,8"/>

        <!-- Название трека и исполнителя — из ID3-тега файла, если тег пустой,
             показываем просто имя файла (см. LoadDemoTrackAsync в code-behind). -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="12,0,12,4">
            <TextBlock x:Name="TrackTitleText" Text="" FontSize="18" FontWeight="SemiBold"
                       Foreground="White" HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="360"/>
            <TextBlock x:Name="TrackArtistText" Text="" FontSize="13"
                       Foreground="{StaticResource AppDimBrush}" HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="360" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="22,0,22,6">
            <TextBlock x:Name="ElapsedText" Text="0:00" Foreground="{StaticResource AppDimBrush}" FontSize="11" VerticalAlignment="Center"/>
            <Slider x:Name="ProgressSlider" Width="230" Margin="10,0" Minimum="0" Maximum="100"
                    ValueChanged="ProgressSlider_ValueChanged"
                    Foreground="{StaticResource AppAccentBrush}"/>
            <TextBlock x:Name="DurationText" Text="0:00" Foreground="{StaticResource AppDimBrush}" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Margin вместо StackPanel.Spacing — совместимо с любой версией UWP,
             начиная с самой первой (Spacing требует контракт v5 / build 16299). -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,26">
            <Button x:Name="PreviousButton" Click="PreviousButton_Click" Background="Transparent" BorderThickness="0">
                <SymbolIcon Symbol="Previous" Foreground="White"/>
            </Button>
            <Grid Width="64" Height="64" Margin="34,0,0,0">
                <!-- Ellipse вместо Button.CornerRadius (требует контракт v7 / SDK 17763+) -->
                <Ellipse Width="64" Height="64" Stroke="{StaticResource AppAccentBrush}" StrokeThickness="2" Fill="Transparent"/>
                <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click"
                        Width="64" Height="64" Background="Transparent" BorderThickness="0">
                    <SymbolIcon x:Name="PlayPauseIcon" Symbol="Play" Foreground="{StaticResource AppAccentBrush}"/>
                </Button>
            </Grid>
            <Button x:Name="NextButton" Click="NextButton_Click" Background="Transparent" BorderThickness="0" Margin="34,0,0,0">
                <SymbolIcon Symbol="Next" Foreground="White"/>
            </Button>
        </StackPanel>
    </Grid>
</Page>
